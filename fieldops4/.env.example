# DATABASE (Supabase Direct Connection)
# Get from: Supabase Dashboard > Project Settings > Database > URI
DATABASE_URL=postgresql://postgres:8780@db.zskdrxohlwmujefecccl.supabase.co:5432/postgres?sslmode=require

# SECRET KEY — generate once, keep forever (sessions break if changed)
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_this_with_your_generated_key

# Flask — set 0 in production
FLASK_DEBUG=0
